# Keep the web Docker image build context lean. The Expo mobile app (apps/)
# never enters the web image; packages/ MUST enter it — since Phase 1 the
# web app depends on the @wealthai/core workspace, and the Dockerfile
# copies packages/ before `npm install` so the workspace link resolves.
node_modules
dist
apps
.git
.github
.playwright-mcp
e2e/screenshots
test-results
ios
*.log
