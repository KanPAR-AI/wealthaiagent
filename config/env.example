# Example Environment Configuration
# Copy this file to .env.local for local development
# Copy this file to .env.production for production builds

# Required: Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# API Configuration
VITE_API_BASE_URL=http://localhost:8080
VITE_API_VERSION=v1

# Application Configuration
VITE_APP_BASE_PATH=
VITE_APP_NAME=WealthAI Agent
VITE_APP_PORT=5173

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Build Configuration
VITE_BUILD_TARGET=development

# Optional: External Services
# VITE_SENTRY_DSN=your_sentry_dsn_here
# VITE_GA_TRACKING_ID=your_ga_tracking_id_here

# Test Credentials (for development only, remove in production)
# VITE_TEST_USERNAME=testuser
# VITE_TEST_PASSWORD=testpass123 