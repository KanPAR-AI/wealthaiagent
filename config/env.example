# Example Environment Configuration
# Copy this file to .env.local for local development
# Copy this file to .env.production for production builds

# Firebase Authentication (required)
# Get these from Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API Configuration
VITE_API_BASE_URL=http://localhost:8080
VITE_API_VERSION=v1

# Application Configuration
VITE_APP_BASE_PATH=
VITE_APP_NAME=WealthAI Agent
VITE_APP_PORT=5173

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Build Configuration
VITE_BUILD_TARGET=development

# Optional: External Services
# VITE_SENTRY_DSN=your_sentry_dsn_here
# VITE_GA_TRACKING_ID=your_ga_tracking_id_here
