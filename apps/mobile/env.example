# Mobile App Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# API Configuration
# =============================================================================

# Backend API Base URL (without /api/v1 suffix)
# For local development:
# - Android Emulator: http://10.0.2.2:8080
# - iOS Simulator: http://localhost:8080
# - Physical Device: http://YOUR_LOCAL_IP:8080 (e.g., http://192.168.1.100:8080)
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# API Version (usually v1)
EXPO_PUBLIC_API_VERSION=v1

# Full API URL (auto-constructed from base + version)
# This will be: ${EXPO_PUBLIC_API_BASE_URL}/api/${EXPO_PUBLIC_API_VERSION}
# Example: http://10.0.2.2:8080/api/v1

# =============================================================================
# Authentication
# =============================================================================

# Test credentials for development (these match your backend)
EXPO_PUBLIC_TEST_USERNAME=test_username
EXPO_PUBLIC_TEST_PASSWORD=kzjdbv

# JWT Token settings
EXPO_PUBLIC_JWT_EXPIRY_MINUTES=30

# =============================================================================
# App Configuration
# =============================================================================

# App name and version
EXPO_PUBLIC_APP_NAME=YourFinAdvisor Mobile
EXPO_PUBLIC_APP_VERSION=1.0.0

# App environment
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_DEBUG=true

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/disable features
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_DEBUG_LOGGING=true
EXPO_PUBLIC_ENABLE_ERROR_REPORTING=false
EXPO_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false

# =============================================================================
# External Services
# =============================================================================

# Sentry for error tracking (optional)
EXPO_PUBLIC_SENTRY_DSN=

# Google Analytics (optional)
EXPO_PUBLIC_GA_TRACKING_ID=

# =============================================================================
# Development & Testing
# =============================================================================

# Enable development features
EXPO_PUBLIC_ENABLE_DEV_TOOLS=true
EXPO_PUBLIC_ENABLE_MOCK_DATA=false
EXPO_PUBLIC_ENABLE_NETWORK_LOGGING=true

# Test mode settings
EXPO_PUBLIC_TEST_MODE=false
EXPO_PUBLIC_MOCK_API_RESPONSES=false

# =============================================================================
# Platform-Specific Configuration
# =============================================================================

# Android-specific settings
EXPO_PUBLIC_ANDROID_API_URL=http://10.0.2.2:8080

# iOS-specific settings  
EXPO_PUBLIC_IOS_API_URL=http://localhost:8080

# Web-specific settings (if running in web mode)
EXPO_PUBLIC_WEB_API_URL=http://localhost:8080

# =============================================================================
# Network & Security
# =============================================================================

# Network timeout settings (in milliseconds)
EXPO_PUBLIC_API_TIMEOUT=30000
EXPO_PUBLIC_UPLOAD_TIMEOUT=60000

# Security settings
EXPO_PUBLIC_ENABLE_SSL_VERIFICATION=true
EXPO_PUBLIC_ALLOW_INSECURE_CONNECTIONS=false

# =============================================================================
# File Upload & Storage
# =============================================================================

# File upload settings
EXPO_PUBLIC_MAX_FILE_SIZE=10485760
EXPO_PUBLIC_ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png

# Storage settings
EXPO_PUBLIC_ENABLE_FILE_CACHING=true
EXPO_PUBLIC_MAX_CACHE_SIZE=100000000

# =============================================================================
# Chat & AI Configuration
# =============================================================================

# Chat settings
EXPO_PUBLIC_MAX_MESSAGE_LENGTH=4000
EXPO_PUBLIC_ENABLE_MESSAGE_HISTORY=true
EXPO_PUBLIC_MESSAGE_HISTORY_LIMIT=100

# AI streaming settings
EXPO_PUBLIC_ENABLE_STREAMING=true
EXPO_PUBLIC_STREAM_CHUNK_SIZE=1024

# =============================================================================
# Performance & Monitoring
# =============================================================================

# Performance thresholds
EXPO_PUBLIC_SLOW_REQUEST_THRESHOLD=1000
EXPO_PUBLIC_MEMORY_WARNING_THRESHOLD=80

# Monitoring intervals (in milliseconds)
EXPO_PUBLIC_HEALTH_CHECK_INTERVAL=30000
EXPO_PUBLIC_PERFORMANCE_LOG_INTERVAL=60000

# =============================================================================
# Local Development Overrides
# =============================================================================

# Override API URL for local development (this takes precedence)
# EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1

# Override all settings for local development
# EXPO_PUBLIC_OVERRIDE_API_CONFIG=true

# =============================================================================
# Notes & Usage
# =============================================================================

# IMPORTANT NOTES:
# 1. All variables must start with EXPO_PUBLIC_ to be accessible in the app
# 2. For Android emulator, use 10.0.2.2 instead of localhost
# 3. For iOS simulator, localhost works fine
# 4. For physical devices, use your computer's local IP address
# 5. Never commit actual .env files to version control
# 6. Use .env.local for local-only overrides

# QUICK SETUP FOR LOCAL DEVELOPMENT:
# 1. Copy this file to .env
# 2. Set EXPO_PUBLIC_API_BASE_URL to your backend URL
# 3. Ensure your backend is running on the specified port
# 4. Restart your mobile app

# COMMON BACKEND URLS:
# - Local development: http://localhost:8080 or http://10.0.2.2:8080
# - Docker: http://localhost:8080 or http://10.0.2.2:8080
# - Production: https://your-backend-domain.com
