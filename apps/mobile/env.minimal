# Minimal Mobile App Environment Configuration
# Copy this file to .env and adjust as needed

# =============================================================================
# REQUIRED: API Configuration
# =============================================================================

# Backend API Base URL (without /api/v1 suffix)
# For Android Emulator: http://10.0.2.2:8080
# For iOS Simulator: http://localhost:8080
# For Physical Device: http://YOUR_LOCAL_IP:8080
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# =============================================================================
# REQUIRED: Authentication
# =============================================================================

# Test credentials (must match your backend)
EXPO_PUBLIC_TEST_USERNAME=test_username
EXPO_PUBLIC_TEST_PASSWORD=kzjdbv

# =============================================================================
# OPTIONAL: Development Features
# =============================================================================

# Enable debug logging
EXPO_PUBLIC_ENABLE_DEBUG_LOGGING=true

# Enable network logging
EXPO_PUBLIC_ENABLE_NETWORK_LOGGING=true

# =============================================================================
# QUICK SETUP INSTRUCTIONS
# =============================================================================

# 1. Copy this file to .env
# 2. Set EXPO_PUBLIC_API_BASE_URL to match your setup:
#    - Android Emulator: http://10.0.2.2:8080
#    - iOS Simulator: http://localhost:8080
#    - Physical Device: http://192.168.1.100:8080 (replace with your IP)
# 3. Ensure your backend is running
# 4. Restart your mobile app
