# Production Environment Configuration
# Copy this file to .env.production and update with real values

# Required: Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_production_clerk_key

# API Configuration
VITE_API_BASE_URL=https://chatbackend.yourfinadvisor.com
VITE_API_VERSION=v1

# Application Configuration
VITE_APP_BASE_PATH=/chataiagent
VITE_APP_NAME=WealthAI Agent
VITE_APP_PORT=443

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# Build Configuration
VITE_BUILD_TARGET=production

# Optional: External Services
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# DO NOT include test credentials in production! 