							"});",
							"",
							"const chats = pm.response.json();",
							"",
							"pm.test(\"Response is an array of chats\", function () {",
							"    pm.expect(chats).to.be.an('array');",
							"    pm.expect(chats.length).to.be.at.least(1);",
							"});",
							"",
							"// Find favorite chats",
							"const favoriteChats = chats.filter(chat => chat.isFavorite);",
							"const nonFavoriteChats = chats.filter(chat => !chat.isFavorite);",
							"",
							"pm.test(\"Favorite chats appear first\", function () {",
							"    if (favoriteChats.length > 0 && nonFavoriteChats.length > 0) {",
							"        // Get the index of the first non-favorite",
							"        const firstNonFavoriteIndex = chats.findIndex(chat => !chat.isFavorite);",
							"        // All chats before this index should be favorites",
							"        for (let i = 0; i < firstNonFavoriteIndex; i++) {",
							"            pm.expect(chats[i].isFavorite).to.be.true;",
							"        }",
							"        console.log(`Found ${favoriteChats.length} favorites at the top of the list`);",
							"    }",
							"});",
							"",
							"pm.test(\"Favorites are sorted by rank (descending)\", function () {",
							"    if (favoriteChats.length > 1) {",
							"        for (let i = 0; i < favoriteChats.length - 1; i++) {",
							"            pm.expect(favoriteChats[i].favoriteRank).to.be.at.least(favoriteChats[i + 1].favoriteRank);",
