# frontend/nginx.template

server {
    listen ${PORT};
    server_name localhost; # Will be ignored by Cloud Run

    port_in_redirect off;


    # This location block will handle both /chataiagent and /chataiagent/
    location /chataiagent {
        # If the request is exactly /chataiagent (no trailing slash),
        # permanently redirect to /chataiagent/
        # This ensures consistent URL and that subsequent relative paths work correctly.
        if ($request_uri = /chataiagent) {
            return 301 /chataiagent/;
        }

        # For requests like /chataiagent/ or /chataiagent/some/path
        alias /usr/share/nginx/html/chataiagent/;
        index index.html index.htm; # Explicitly define index files
        try_files $uri $uri/ /chataiagent/index.html; # Serve SPA

        # Firebase signInWithPopup needs the parent to keep its window.opener
        # handle when the popup (aiagentapi.firebaseapp.com) returns. Chrome
        # 119+ severs the opener relationship unless the parent explicitly
        # opts in via COOP=same-origin-allow-popups. Without this, Google
        # sign-in popup completes but the credential never posts back —
        # symptom: popup hangs / can't close, parent stays anonymous.
        add_header Cross-Origin-Opener-Policy "same-origin-allow-popups" always;
    }

    # Root → redirect to /chataiagent/ (React app lives there).
    # Works for both chat.yourfinadvisor.com and astro.yourfinadvisor.com —
    # the React app detects the hostname and switches to MysticAI mode.
    location = / {
        return 302 /chataiagent/;
    }

    # Health check endpoint
    location = /_healthz {
        access_log off;
        return 200 "healthy";
        add_header Content-Type text/plain;
    }

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_http_version 1.1;
    gzip_types text/plain text/css application/json application/javascript application/x-javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml;
}